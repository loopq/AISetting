{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {},
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(du *)",
      "Bash(file *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(git log *)",
      "Bash(git fetch *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git show *)",
      "Bash(git add *)",
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "Bash(./gradlew assembleDebug:*)",
      "mcp__figma__get_screenshot",
      "mcp__figma__get_design_context",
      "Bash(brew list:*)",
      "Bash(brew info:*)",
      "Bash(brew install:*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/loopq/.claude/plugins/cache/hamel-review/review-loop/1.8.0/hooks/stop-hook.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/loopq/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "firebase@firebase": true,
    "frontend-design@claude-plugins-official": true,
    "review-loop@hamel-review": true,
    "superpowers@superpowers-marketplace": true
  },
  "extraKnownMarketplaces": {
    "hamel-review": {
      "source": {
        "source": "github",
        "repo": "hamelsmu/claude-review-loop"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "hasCompletedOnboarding": true
}
